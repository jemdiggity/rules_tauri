+fn current_execroot_main() -> Option<PathBuf> {
+  env::current_dir().ok().and_then(|cwd| {
+    cwd.ancestors()
+      .find(|path| {
+        path.file_name() == Some(OsStr::new("_main"))
+          && path.parent().and_then(Path::file_name) == Some(OsStr::new("execroot"))
+      })
+      .map(PathBuf::from)
+  })
+}
+
+fn remap_bazel_execroot_path(path: PathBuf) -> PathBuf {
+  if path.exists() {
+    return path;
+  }
+
+  let Some(execroot_main) = current_execroot_main() else {
+    return path;
+  };
+
+  let mut components = path.components().peekable();
+  while let Some(component) = components.next() {
+    if component == Component::Normal(OsStr::new("execroot"))
+      && components.peek() == Some(&Component::Normal(OsStr::new("_main")))
+    {
+      let _ = components.next();
+      let suffix = components.fold(PathBuf::new(), |mut acc, component| {
+        acc.push(component.as_os_str());
+        acc
+      });
+      let remapped = execroot_main.join(suffix);
+      if remapped.exists() {
+        return remapped;
+      }
+      break;
+    }
+  }
+
+  path
+}
